{{!< default}}
{{#post}}
<article id="{{comment_id}}" class="{{post_class}}">
	{{#if @page.show_title_and_feature_image}}
		<h1 class="post-title">{{title}}</h1>
		{{#if feature_image}}
			<img class="feature-image" src="{{img_url feature_image size="xl"}}" alt="{{title}}" />
		{{/if}}
	{{/if}}
	{{content}}
</article>
{{/post}}